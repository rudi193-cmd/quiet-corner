  "thesis": {
    "one_line": "Assessment systems optimized for visible output under-see learning; AI intensifies that blind spot; expanding expressive pathways and assessment visibility increases accuracy and equity without lowering standards.",
    "core_problem": "It is not that students are learning differently—it is that assessment systems are insufficiently sensitive to how learning actually appears.",
    "shift": "From performance acceleration to assessment visibility"
  },
  "principles": [
    {
      "id": "p1",
      "title": "Learning is not synonymous with performance",
      "summary": "Understanding emerges through reflection, integration, and time."
    },
    {
      "id": "p2",
      "title": "Assessment visibility is an equity issue",
      "summary": "When only narrow expression counts, capable learners are systematically under-seen."
    },
    {
      "id": "p3",
      "title": "Multiple expressive pathways strengthen rigor",
      "summary": "Diverse demonstrations increase accuracy without diluting expectations."
    },
    {
      "id": "p4",
      "title": "Teacher judgment is central and irreplaceable",
      "summary": "No tool or system supersedes professional observation."
    },
    {
      "id": "p5",
      "title": "Tools must follow cognition, not precede it",
      "summary": "Engagement and sense-making come before articulation or AI support."
    }
  ],
  "expressive_pathways": [
    "embodied_performative",
    "verbal_oral",
    "reflective_delayed",
    "in_role_narrative",
    "written",
    "visual_representational"
  ],
  "ai_position": {
    "role": "constrained_secondary_scaffold",
    "legitimate_uses": [
